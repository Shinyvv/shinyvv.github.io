---
---

<section id="portfolio" class="py-20 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-display font-bold text-dark-900 mb-6">
        Our <span class="text-primary-coral">Portfolio</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Discover some of our recent projects that showcase our expertise and creativity
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Project 1 -->
      <div class="portfolio-item group relative overflow-hidden rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:scale-105">
        <div class="aspect-w-16 aspect-h-12 bg-gradient-to-br from-primary-blue to-primary-coral">
          <img src="https://images.pexels.com/photos/196644/pexels-photo-196644.jpeg?auto=compress&cs=tinysrgb&w=800" alt="E-commerce Platform" class="w-full h-64 object-cover">
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-dark-900/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <div class="absolute bottom-0 left-0 right-0 p-6 text-white transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
            <h3 class="text-xl font-bold mb-2">E-commerce Platform</h3>
            <p class="text-sm text-white/90 mb-4">Modern online store with advanced filtering and payment integration</p>
            <div class="flex space-x-2">
              <span class="px-3 py-1 bg-primary-blue rounded-full text-xs">React</span>
              <span class="px-3 py-1 bg-primary-coral rounded-full text-xs">Node.js</span>
              <span class="px-3 py-1 bg-primary-yellow rounded-full text-xs">MongoDB</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Project 2 -->
      <div class="portfolio-item group relative overflow-hidden rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:scale-105">
        <div class="aspect-w-16 aspect-h-12 bg-gradient-to-br from-primary-coral to-primary-yellow">
          <img src="https://images.pexels.com/photos/3184291/pexels-photo-3184291.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Corporate Website" class="w-full h-64 object-cover">
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-dark-900/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <div class="absolute bottom-0 left-0 right-0 p-6 text-white transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
            <h3 class="text-xl font-bold mb-2">Corporate Website</h3>
            <p class="text-sm text-white/90 mb-4">Professional business website with CMS integration and analytics</p>
            <div class="flex space-x-2">
              <span class="px-3 py-1 bg-primary-blue rounded-full text-xs">WordPress</span>
              <span class="px-3 py-1 bg-primary-coral rounded-full text-xs">PHP</span>
              <span class="px-3 py-1 bg-primary-yellow rounded-full text-xs">MySQL</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Project 3 -->
      <div class="portfolio-item group relative overflow-hidden rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:scale-105">
        <div class="aspect-w-16 aspect-h-12 bg-gradient-to-br from-primary-yellow to-primary-cream">
          <img src="https://images.pexels.com/photos/3184338/pexels-photo-3184338.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Mobile App" class="w-full h-64 object-cover">
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-dark-900/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <div class="absolute bottom-0 left-0 right-0 p-6 text-white transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
            <h3 class="text-xl font-bold mb-2">Mobile App Interface</h3>
            <p class="text-sm text-white/90 mb-4">Intuitive mobile application with seamless user experience</p>
            <div class="flex space-x-2">
              <span class="px-3 py-1 bg-primary-blue rounded-full text-xs">React Native</span>
              <span class="px-3 py-1 bg-primary-coral rounded-full text-xs">Firebase</span>
              <span class="px-3 py-1 bg-primary-yellow rounded-full text-xs">Redux</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Project 4 -->
      <div class="portfolio-item group relative overflow-hidden rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:scale-105">
        <div class="aspect-w-16 aspect-h-12 bg-gradient-to-br from-primary-cream to-white">
          <img src="https://images.pexels.com/photos/3184465/pexels-photo-3184465.jpeg?auto=compress&cs=tinysrgb&w=800" alt="SaaS Platform" class="w-full h-64 object-cover">
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-dark-900/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <div class="absolute bottom-0 left-0 right-0 p-6 text-white transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
            <h3 class="text-xl font-bold mb-2">SaaS Platform</h3>
            <p class="text-sm text-white/90 mb-4">Scalable software-as-a-service platform with multi-tenant architecture</p>
            <div class="flex space-x-2">
              <span class="px-3 py-1 bg-primary-blue rounded-full text-xs">Vue.js</span>
              <span class="px-3 py-1 bg-primary-coral rounded-full text-xs">Laravel</span>
              <span class="px-3 py-1 bg-primary-yellow rounded-full text-xs">PostgreSQL</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Project 5 -->
      <div class="portfolio-item group relative overflow-hidden rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:scale-105">
        <div class="aspect-w-16 aspect-h-12 bg-gradient-to-br from-dark-800 to-dark-900">
          <img src="https://images.pexels.com/photos/3184360/pexels-photo-3184360.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Portfolio Website" class="w-full h-64 object-cover">
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-dark-900/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <div class="absolute bottom-0 left-0 right-0 p-6 text-white transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
            <h3 class="text-xl font-bold mb-2">Creative Portfolio</h3>
            <p class="text-sm text-white/90 mb-4">Stunning portfolio website for creative professionals</p>
            <div class="flex space-x-2">
              <span class="px-3 py-1 bg-primary-blue rounded-full text-xs">Gatsby</span>
              <span class="px-3 py-1 bg-primary-coral rounded-full text-xs">GraphQL</span>
              <span class="px-3 py-1 bg-primary-yellow rounded-full text-xs">Contentful</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Project 6 -->
      <div class="portfolio-item group relative overflow-hidden rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:scale-105">
        <div class="aspect-w-16 aspect-h-12 bg-gradient-to-br from-primary-blue via-primary-coral to-primary-yellow">
          <img src="https://images.pexels.com/photos/3184317/pexels-photo-3184317.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Dashboard Application" class="w-full h-64 object-cover">
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-dark-900/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <div class="absolute bottom-0 left-0 right-0 p-6 text-white transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
            <h3 class="text-xl font-bold mb-2">Analytics Dashboard</h3>
            <p class="text-sm text-white/90 mb-4">Real-time analytics dashboard with interactive data visualization</p>
            <div class="flex space-x-2">
              <span class="px-3 py-1 bg-primary-blue rounded-full text-xs">Angular</span>
              <span class="px-3 py-1 bg-primary-coral rounded-full text-xs">D3.js</span>
              <span class="px-3 py-1 bg-primary-yellow rounded-full text-xs">Express</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="text-center mt-12">
      <a href="#contact" class="bg-primary-blue hover:bg-primary-coral text-white px-8 py-4 rounded-full font-semibold transition-all duration-300 transform hover:scale-105 shadow-lg">
        Start Your Project
      </a>
    </div>
  </div>
</section>