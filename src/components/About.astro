---
---

<section id="about" class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="order-2 lg:order-1">
        <h2 class="text-4xl md:text-5xl font-display font-bold text-dark-900 mb-6">
          About <span class="text-primary-yellow">DasPix</span>
        </h2>
        <p class="text-xl text-gray-600 mb-6">
          We are a passionate team of web developers, designers, and digital strategists dedicated to creating exceptional online experiences.
        </p>
        <p class="text-gray-600 mb-8">
          Founded with the vision of bridging the gap between creativity and technology, DasPix has been helping businesses establish their digital presence with innovative solutions that drive growth and engagement.
        </p>
        
        <div class="grid grid-cols-2 gap-6 mb-8">
          <div class="text-center p-4 bg-primary-cream rounded-lg">
            <div class="text-3xl font-bold text-primary-blue mb-2">50+</div>
            <div class="text-sm text-gray-600">Projects Completed</div>
          </div>
          <div class="text-center p-4 bg-primary-cream rounded-lg">
            <div class="text-3xl font-bold text-primary-coral mb-2">3+</div>
            <div class="text-sm text-gray-600">Years Experience</div>
          </div>
          <div class="text-center p-4 bg-primary-cream rounded-lg">
            <div class="text-3xl font-bold text-primary-yellow mb-2">40+</div>
            <div class="text-sm text-gray-600">Happy Clients</div>
          </div>
          <div class="text-center p-4 bg-primary-cream rounded-lg">
            <div class="text-3xl font-bold text-primary-blue mb-2">24/7</div>
            <div class="text-sm text-gray-600">Support</div>
          </div>
        </div>

        <div class="flex flex-wrap gap-4">
          <span class="px-4 py-2 bg-primary-blue text-white rounded-full text-sm">React</span>
          <span class="px-4 py-2 bg-primary-coral text-white rounded-full text-sm">Node.js</span>
          <span class="px-4 py-2 bg-primary-yellow text-dark-900 rounded-full text-sm">WordPress</span>
          <span class="px-4 py-2 bg-primary-cream text-dark-900 rounded-full text-sm">Shopify</span>
          <span class="px-4 py-2 bg-gray-200 text-dark-900 rounded-full text-sm">AWS</span>
        </div>
      </div>

      <div class="order-1 lg:order-2 relative">
        <div class="relative">
          <img src="https://images.pexels.com/photos/3184291/pexels-photo-3184291.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Team working" class="rounded-2xl shadow-2xl">
          <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-primary-yellow rounded-2xl flex items-center justify-center">
            <div class="text-center">
              <div class="text-2xl font-bold text-dark-900">100%</div>
              <div class="text-xs text-dark-700">Satisfaction</div>
            </div>
          </div>
        </div>
        
        <!-- Floating elements -->
        <div class="absolute -top-4 -left-4 w-20 h-20 bg-primary-blue rounded-full opacity-20 animate-float"></div>
        <div class="absolute top-1/2 -right-8 w-16 h-16 bg-primary-coral rounded-full opacity-30 animate-float" style="animation-delay: -2s;"></div>
      </div>
    </div>

    <!-- Team Values -->
    <div class="mt-20">
      <h3 class="text-3xl font-display font-bold text-center text-dark-900 mb-12">Our Values</h3>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-primary-blue rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h4 class="text-xl font-bold text-dark-900 mb-3">Quality First</h4>
          <p class="text-gray-600">We never compromise on quality and always deliver exceptional results that exceed expectations.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-primary-coral rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3z"></path>
            </svg>
          </div>
          <h4 class="text-xl font-bold text-dark-900 mb-3">Client-Focused</h4>
          <p class="text-gray-600">Your success is our success. We work closely with you to understand and achieve your goals.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-primary-yellow rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-dark-900" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <h4 class="text-xl font-bold text-dark-900 mb-3">Innovation</h4>
          <p class="text-gray-600">We stay ahead of the curve with the latest technologies and creative solutions.</p>
        </div>
      </div>
    </div>
  </div>
</section>